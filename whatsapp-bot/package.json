{
  "name": "honduraite-whatsapp-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Bot temporal de WhatsApp (no oficial) + export de teléfonos HonduRaite. Usar solo en número SECUNDARIO.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "export": "node export-phones.js",
    "export:drivers": "node export-phones.js --role=driver",
    "export:clients": "node export-phones.js --role=client",
    "send": "node send-campaign.js",
    "send:dry": "node send-campaign.js --dry-run",
    "login": "node login.js",
    "login:fresh": "node login.js --fresh",
    "worker": "node worker.js"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  }
}
